nextflow_pipeline {

    name "Test Workflow main.nf"
    script "../main.nf"
    tag "pipeline"

    test("Test targeted full") {

        when {
            params {
                outdir          = "${outputDir}"
                input           = "https://raw.githubusercontent.com/nf-core/test-datasets/crisprseq/testdata-edition/samplesheet_test_full.csv"
                analysis        = 'targeted'
                aligner         = 'minimap2'
                overrepresented = true
            }
        }

        then {
            assert workflow.success
        }

    }

}
