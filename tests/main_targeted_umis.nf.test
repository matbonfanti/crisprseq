nextflow_pipeline {

    name "Test Workflow main.nf"
    script "../main.nf"
    tag "pipeline"

    test("Test targeted UMIs") {

        when {
            params {
                outdir         = "${outputDir}/results_targeted_umis"
                input          = "https://raw.githubusercontent.com/nf-core/test-datasets/crisprseq/testdata-edition/samplesheet_test_umis.csv"
                analysis       = 'targeted'
                aligner        = 'minimap2'
                umi_clustering = true

            }
        }

        then {
            assert workflow.success
        }

    }

}
